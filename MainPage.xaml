<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AppScanner.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="#f4f6f9"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*">

        <!-- HEADER -->
        <Grid BackgroundColor="#1e1e2f" HeightRequest="60">
            <Label x:Name="LblFecha"
                   Text="Precios"
                   TextColor="White"
                   FontSize="18"
                   FontAttributes="Bold"
                   VerticalOptions="Center"
                   HorizontalOptions="Center"/>
        </Grid>

        <!-- CONTENIDO -->
        <VerticalStackLayout Grid.Row="1"
                             Padding="20"
                             Spacing="20"
                             VerticalOptions="Center">

            <!-- ROW PRECIOS -->
            <Grid ColumnDefinitions="*,*"
                  ColumnSpacing="15">

                <!-- CARD PRECIO COMIDA -->
                <Frame Grid.Column="0"
                       CornerRadius="20"
                       HasShadow="True"
                       Padding="20"
                       BackgroundColor="White">

                    <VerticalStackLayout Spacing="5">

                        <Label Text="Comida"
                               FontSize="14"
                               TextColor="Gray"/>

                        <Label x:Name="LblPrecioComida"
                               Text="0.00"
                               FontSize="28"
                               FontAttributes="Bold"
                               TextColor="#16a34a"/>
                    </VerticalStackLayout>
                </Frame>

                <!-- CARD PRECIO DESAYUNO -->
                <Frame Grid.Column="1"
                       CornerRadius="20"
                       HasShadow="True"
                       Padding="20"
                       BackgroundColor="White">

                    <VerticalStackLayout Spacing="5">

                        <Label Text="Desayuno"
                               FontSize="14"
                               TextColor="Gray"/>

                        <Label x:Name="LblPrecioDesayuno"
                               Text="0.00"
                               FontSize="28"
                               FontAttributes="Bold"
                               TextColor="#f59e0b"/>
                    </VerticalStackLayout>
                </Frame>

            </Grid>

            <!-- COMIDA -->
            <Frame x:Name="CardComida"
                   CornerRadius="20"
                   HasShadow="True"
                   Padding="18"
                   BackgroundColor="White">

                <Grid ColumnDefinitions="Auto,*,Auto"
                      ColumnSpacing="15">

                    <Image Source="comida.png"
                           WidthRequest="45"
                           HeightRequest="45"
                           VerticalOptions="Center"/>

                    <VerticalStackLayout Grid.Column="1"
                                         VerticalOptions="Center">

                        <Label Text="Comida"
                               FontSize="17"
                               FontAttributes="Bold"
                               TextColor="#1e1e2f"/>

                        <Label Text="Registrar comida del día"
                               FontSize="13"
                               TextColor="Gray"/>
                    </VerticalStackLayout>

                    <Label Grid.Column="2"
                           Text="›"
                           FontSize="22"
                           TextColor="#3b82f6"
                           VerticalOptions="Center"/>
                </Grid>

                <Frame.GestureRecognizers>
                    <TapGestureRecognizer
                        Tapped="OnOperacionTapped"
                        CommandParameter="Comida"/>
                </Frame.GestureRecognizers>
            </Frame>

            <!-- DESAYUNO -->
            <Frame x:Name="CardDesayuno"
                   CornerRadius="20"
                   HasShadow="True"
                   Padding="18"
                   BackgroundColor="White">

                <Grid ColumnDefinitions="Auto,*,Auto"
                      ColumnSpacing="15">

                    <Image Source="desayuno.png"
                           WidthRequest="45"
                           HeightRequest="45"
                           VerticalOptions="Center"/>

                    <VerticalStackLayout Grid.Column="1"
                                         VerticalOptions="Center">

                        <Label Text="Desayuno"
                               FontSize="17"
                               FontAttributes="Bold"
                               TextColor="#1e1e2f"/>

                        <Label Text="Registrar desayuno"
                               FontSize="13"
                               TextColor="Gray"/>
                    </VerticalStackLayout>

                    <Label Grid.Column="2"
                           Text="›"
                           FontSize="22"
                           TextColor="#3b82f6"
                           VerticalOptions="Center"/>
                </Grid>

                <Frame.GestureRecognizers>
                    <TapGestureRecognizer
                        Tapped="OnOperacionTapped"
                        CommandParameter="Desayuno"/>
                </Frame.GestureRecognizers>
            </Frame>

            <!-- PEDIDO -->
            <Frame x:Name="CardPedido"
                   CornerRadius="20"
                   HasShadow="True"
                   Padding="18"
                   BackgroundColor="White">

                <Grid ColumnDefinitions="Auto,*,Auto"
                      ColumnSpacing="15">

                    <Image Source="pedido.png"
                           WidthRequest="45"
                           HeightRequest="45"
                           VerticalOptions="Center"/>

                    <VerticalStackLayout Grid.Column="1"
                                         VerticalOptions="Center">

                        <Label Text="Pedido"
                               FontSize="17"
                               FontAttributes="Bold"
                               TextColor="#1e1e2f"/>

                        <Label Text="Registrar pedidos especiales"
                               FontSize="13"
                               TextColor="Gray"/>
                    </VerticalStackLayout>

                    <Label Grid.Column="2"
                           Text="›"
                           FontSize="22"
                           TextColor="#3b82f6"
                           VerticalOptions="Center"/>
                </Grid>

                <Frame.GestureRecognizers>
                    <TapGestureRecognizer
                        Tapped="OnOperacionTapped"
                        CommandParameter="Pedido"/>
                </Frame.GestureRecognizers>
            </Frame>

        </VerticalStackLayout>

    </Grid>
</ContentPage>